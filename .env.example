# PostgreSQL
POSTGRES_DB=deciva
POSTGRES_USER=deciva_user
POSTGRES_PASSWORD=PasswordSinCaracteresEspeciales

# Port exposed on the VPS
PORT=9512

# Full connection string — must match the values above (no special chars in password)
DB_CONNECTION=Host=db-deciva;Port=5432;Database=deciva;Username=deciva_user;Password=PasswordSinCaracteresEspeciales
